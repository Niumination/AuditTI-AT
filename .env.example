# OpenRouter API Key — https://openrouter.ai/keys
# Dapatkan key baru di https://openrouter.ai/settings/keys
VITE_OPENROUTER_KEY=sk-or-v1-xxxxxxxxxxxx

# Model override (opsional, default: google/gemini-2.0-flash-001)
# Model gratis lain: google/gemma-2-27b-it, meta-llama/llama-3.2-3b-instruct
VITE_OPENROUTER_MODEL=google/gemini-2.0-flash-001
